# dave-wang-6c2c-daily-video example environment.
# Copy to .env or load these variables with your process manager.

# Server
# Optional. Defaults to 0.0.0.0:8080 when unset.
HOST=0.0.0.0
PORT=8080
RUST_LOG=info,dave_wang_6c2c_daily_video=info

# PostgreSQL
# Required. Persistent state must use PostgreSQL; SQLite and local files are not supported.
DATABASE_URL=postgres://user:password@host:5432/dave_wang_6c2c_daily_video

# Local pipeline workspace
# Optional. Stores temporary raw clips, frames, GLBs, and assembled MP4s before upload.
PIPELINE_WORKSPACE_DIR=/var/lib/dave-wang-6c2c-daily-video/work

# Tigris S3-compatible object storage
# Required. Use these exact variable names; do not rename to S3_* or AWS_* aliases.
# OBJECT_STORAGE_PREFIX must end with a trailing slash and is prepended to every object key.
OBJECT_STORAGE_ACCESS_KEY_ID=tid_example_access_key
OBJECT_STORAGE_SECRET_ACCESS_KEY=tsec_example_secret_key
OBJECT_STORAGE_BUCKET=dave-wang-6c2c-daily-video
OBJECT_STORAGE_PREFIX=app_dave_wang_6c2c_daily_video_ab116e/
OBJECT_STORAGE_ENDPOINT=https://fly.storage.tigris.dev
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# External providers
VIDEO_PROVIDER=gemini_veo
IMAGE_TO_3D_PROVIDER=meshy
GEMINI_API_KEY=gemini_example_api_key
MESHY_API_KEY=meshy_example_api_key

# Daily scheduler configuration
# Time is HH:MM in SCHEDULE_TIMEZONE.
SCHEDULE_TIME=08:00
SCHEDULE_TIMEZONE=UTC

# Admin API
# Send as: Authorization: Bearer <ADMIN_API_KEY>
ADMIN_API_KEY=replace_with_a_long_random_value
