# Server
# Optional. Defaults to 0.0.0.0:8080 when unset.
HOST=0.0.0.0
PORT=8080

# PostgreSQL
DATABASE_URL=postgres://user:password@host:5432/dave_wang_6c2c_daily_video

# Tigris S3-compatible object storage
OBJECT_STORAGE_ACCESS_KEY_ID=tid_example_access_key
OBJECT_STORAGE_SECRET_ACCESS_KEY=tsec_example_secret_key
OBJECT_STORAGE_BUCKET=dave-wang-6c2c-daily-video
OBJECT_STORAGE_PREFIX=app_dave_wang_6c2c_daily_video_ab116e/
OBJECT_STORAGE_ENDPOINT=https://fly.storage.tigris.dev
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# External providers
VIDEO_PROVIDER=gemini_veo
IMAGE_TO_3D_PROVIDER=meshy
GEMINI_API_KEY=gemini_example_api_key
MESHY_API_KEY=meshy_example_api_key

# Daily scheduler
SCHEDULE_TIME=08:00
SCHEDULE_TIMEZONE=UTC

# Admin API
ADMIN_API_KEY=replace_with_a_long_random_value
